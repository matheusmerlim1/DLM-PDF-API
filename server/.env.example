# ════════════════════════════════════════════════════════════
#  DLM-PDF Server — Variáveis de Ambiente
#  Copie este arquivo para .env e ajuste os valores
# ════════════════════════════════════════════════════════════

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=troque_por_segredo_forte_em_producao_min32chars
JWT_EXPIRES_IN=1h

# ── Criptografia .dlm ────────────────────────────────────────
# Chave mestra AES (64 hex chars = 32 bytes)
MASTER_ENCRYPTION_KEY=4f8ef74f8ef74f8ef74f8ef74f8ef74f8ef74f8ef74f8ef74f8ef74f8ef74f8e

# ════════════════════════════════════════════════════════════
#  BLOCKCHAIN — escolha UMA das opções abaixo
# ════════════════════════════════════════════════════════════

# ── OPÇÃO 1: MODO DEMO (sem blockchain) ─────────────────────
# Servidor sobe imediatamente, respostas simuladas em memória.
# Ideal para testar a API sem configurar nenhum node Ethereum.
#
CONTRACT_ADDRESS=demo

# ── OPÇÃO 2: HARDHAT NODE LOCAL (desenvolvimento) ───────────
# 1. Suba o node:   npx hardhat node
# 2. Faça deploy:   npx hardhat run scripts/deploy.js --network localhost
# 3. Cole o endereço gerado em CONTRACT_ADDRESS abaixo
#
# BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
# CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# ORACLE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── OPÇÃO 3: TESTNET SEPOLIA (Ethereum público) ──────────────
# BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/SEU_PROJECT_ID
# CONTRACT_ADDRESS=0x<endereço após deploy na Sepolia>
# ORACLE_PRIVATE_KEY=0x<sua chave privada — NUNCA commite no git>
