{
  "name": "dlm-pdf-server",
  "version": "1.0.0",
  "description": "Servidor de autenticação DLM-PDF — Oráculo Blockchain para licenças de e-books",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start":   "node src/index.js",
    "dev":     "nodemon src/index.js",
    "test":    "node --experimental-vm-modules node_modules/.bin/jest",
    "compile": "cd .. && npx hardhat compile"
  },
  "dependencies": {
    "ethers":        "^6.11.1",
    "express":       "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet":        "^7.1.0",
    "cors":          "^2.8.5",
    "dotenv":        "^16.4.5",
    "crypto":        "^1.0.1",
    "jsonwebtoken":  "^9.0.2",
    "winston":       "^3.13.0"
  },
  "devDependencies": {
    "hardhat":              "^2.22.4",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "nodemon": "^3.1.4"
  }
}
