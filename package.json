{
  "name": "dlm-pdf",
  "version": "1.0.0",
  "description": "DLM-PDF: Gestão de Posse Digital de E-books via Blockchain",
  "private": true,
  "workspaces": ["server"],
  "scripts": {
    "start":         "node server/src/index.js",
    "node:install":  "npm install --prefix server",
    "node:dev":      "npm run dev --prefix server",
    "node:start":    "npm run start --prefix server",
    "chain:install": "npm install",
    "chain:node":    "npx hardhat node",
    "chain:deploy":  "npx hardhat run scripts/deploy.js --network localhost",
    "chain:test":    "npx hardhat test"
  },
  "devDependencies": {
    "hardhat":              "^2.22.4",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0"
  }
}
